// إعدادات Prisma لإنشاء الأكواد البرمجية
generator client {
  provider = "prisma-client-js"
}

// تحديد نوع قاعدة البيانات ومكانها (PostgreSQL)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. جدول الطلاب
model Student {
  id        String   @id @default(cuid())
  code      String   @unique // الكود السري (يجب أن يكون غير مكرر)
  name      String   // اسم الطالب
  grades    Grade[]  // علاقة: الطالب له عدة درجات
  createdAt DateTime @default(now())
}

// 2. جدول المواد
model Subject {
  id        String            @id @default(cuid())
  name      String            @unique // اسم المادة
  divisions SubjectDivision[] // أقسام المادة
  grades    Grade[]           // علاقة: المادة لها عدة درجات للطلاب
  createdAt DateTime          @default(now())
}

// 2.5 أقسام المادة (مثلاً ميدتيرم، فاينل، نشاط)
model SubjectDivision {
  id        String   @id @default(cuid())
  name      String   // اسم القسم
  maxScore  Float?   // الدرجة القصوى (اختياري)
  
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  grades    Grade[]

  @@unique([subjectId, name]) // لا يتكرر نفس القسم لنفس المادة
  createdAt DateTime @default(now())
}

// 3. جدول الدرجات
model Grade {
  id        String   @id @default(cuid())
  score     Float    // الدرجة (رقمية لتسهيل الحسابات)
  
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  divisionId String
  division   SubjectDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  // تحديث: الطالب ما تتكرر درجته في نفس القسم لنفس المادة
  @@unique([studentId, divisionId], name: "studentId_divisionId")
  
  createdAt DateTime @default(now())
}
